# Railway: set these to JUST the reference (no protocol, no /api suffix)
# The code prepends https:// and appends /api automatically.
# Example:
#   NEXT_PUBLIC_API_URL=${{ backend.RAILWAY_PUBLIC_DOMAIN }}
#   NEXT_PUBLIC_WS_URL=${{ backend.RAILWAY_PUBLIC_DOMAIN }}
NEXT_PUBLIC_API_URL=localhost:5000
NEXT_PUBLIC_WS_URL=localhost:5000
